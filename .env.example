# VibeMatch Environment Variables
# Copy this file to .env and fill in the values

# Database — SQLite connection string (required)
DATABASE_URL="file:./dev.db"

# App URL — Public URL of the app, used for CORS and OG images (required)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API URL — Base URL for API calls (optional, defaults to APP_URL/api)
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Socket.io chat service URL (optional, needed for real-time chat)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3003"

# Google Maps API key for map features (optional, Leaflet used as fallback)
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// VibeMatch user (guests + hosts)
model User {
  id          String   @id @default(cuid())
  phone       String   @unique
  name        String
  username    String?  @unique
  bio         String?
  avatarUrl   String?
  city        String?
  profession  String?  // Student | Software eng. | Designer | Healthcare | Finance | Other
  // social handles (UI-only for now, but stored)
  instagram   String?
  // vibe preferences saved from onboarding (comma-separated tags) — powers "For You" feed
  vibePrefs   String   @default("")
  // stats
  vibes       Int      @default(0)
  hosted      Int      @default(0)
  rating      Float    @default(5.0)
  ratingCount Int      @default(0)
  // Guest TRUST score — given by hosts after a party (1..5). Avg of all
  // trust ratings received. High trust = reliable guest. Shown on the
  // guest's profile so future hosts have an assurity signal.
  trustScore  Float    @default(5.0)
  trustCount  Int      @default(0)
  // moderation
  blocked     String   @default("") // comma-separated user ids
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parties      Party[]      @relation("HostedParties")
  joinRequests JoinRequest[]
  sentMessages Message[]    @relation("SentMessages")
  recvMessages Message[]    @relation("RecvMessages")
  threadsA     ChatThread[] @relation("ThreadUserA")
  threadsB     ChatThread[] @relation("ThreadUserB")
  savedParties SavedParty[]
  reviews      Review[]
  orders       Order[]
  tickets      Ticket[]
  trustGiven   TrustRating[] @relation("TrustGiven")
  trustReceived TrustRating[] @relation("TrustReceived")
  groupMembers GroupChatMember[]
}

model Party {
  id          String   @id @default(cuid())
  title       String
  city        String
  area        String
  date        String   // ISO date yyyy-mm-dd
  time        String   // HH:mm
  fee         Int      @default(0) // in major currency units (£ or ₹)
  maxGuests   Int      @default(10)
  vibes       String   @default("") // comma-separated vibe tags
  description String   @default("")
  hostName    String
  hostId      String?
  coverUrl    String?
  // geographic coordinates for the map view (party venue pin)
  lat         Float?
  lng         Float?
  // denormalized stats for fast reads
  guestCount  Int      @default(0)
  // Host controls (spec slide 9 — Admin controls)
  approvalRequired Boolean  @default(true)
  acceptJoiners    Boolean  @default(true)
  menuOpen         Boolean  @default(true)
  // Security/bouncer booking add-on — host can opt in during party creation.
  // Platform takes 15-20% booking fee; bouncer gets the rest after the event.
  securityBooked   Boolean  @default(false)
  securityFee      Int      @default(0) // total fee paid (£ or ₹)
  securityStatus   String   @default("") // "" | "requested" | "confirmed" | "completed"
  // When the exact address is revealed to confirmed guests (spec slide 6 — location drop)
  locationRevealAt DateTime?
  // ===== New (purchase-flow rewrite) =====
  // Flipped to true once the first guest pays for a spot. Unlocks the group
  // chat for that party (shown in the guest's "Active events" section). Host
  // can also flip it manually from the manage-party screen.
  groupChatEnabled Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  host    User?         @relation("HostedParties", fields: [hostId], references: [id])
  requests JoinRequest[]
  savedBy  SavedParty[]
  views    PartyView[]
  reviews  Review[]
  menuItems MenuItem[]
  orders    Order[]
  tickets   Ticket[]
  trustRatings TrustRating[]
  media     PartyMedia[]
  groupChat GroupChat?
}

// ===== Party media gallery — host can attach multiple photos + videos =====
// Stored as a sorted list per party. type = "image" | "video". coverUrl on
// Party stays for backwards-compat as the primary cover; PartyMedia holds the
// full gallery (the cover is usually also media[0]).
model PartyMedia {
  id        String   @id @default(cuid())
  partyId   String
  url       String   // image or video URL
  type      String   @default("image") // "image" | "video"
  caption   String   @default("")
  position  Int      @default(0) // sort order
  createdAt DateTime @default(now())

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId])
}

model JoinRequest {
  id            String   @id @default(cuid())
  partyId       String
  requesterName String
  introMessage  String
  status        String   @default("pending") // pending | accepted | rejected
  requesterId   String?
  // ===== New (purchase-flow rewrite) =====
  // 1:1 chat thread with the host that was opened when the guest clicked
  // "Get your spot". Lets the chat screen show the approval status + Pay CTA.
  threadId      String?
  // Optional intro video the guest attached to their application — played
  // inline in the host's requests list so they can vet the guest quickly.
  introVideoUrl   String?
  introVideoPoster String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  party     Party @relation(fields: [partyId], references: [id])
  requester User? @relation(fields: [requesterId], references: [id])
}

// 1-on-1 chat thread between two users (typically host <-> guest after a request is accepted)
model ChatThread {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  partyId   String?  // optional context: which party sparked the chat
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userA    User      @relation("ThreadUserA", fields: [userAId], references: [id])
  userB    User      @relation("ThreadUserB", fields: [userBId], references: [id])
  messages Message[]
}

model Message {
  id         String   @id @default(cuid())
  threadId   String
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  // ===== New (purchase-flow rewrite) =====
  // kind = "text" (default) | "video" (intro clip) | "system" (approval
  // status updates rendered as centered pills) | "payment" (a WhatsApp-like
  // "Pay {amount}" CTA card the guest taps to complete checkout).
  kind       String   @default("text")
  mediaUrl   String?
  // For payment-cta messages: the join-request id this payment corresponds to,
  // so the chat can mark it paid once the order goes through.
  requestId  String?
  createdAt  DateTime @default(now())

  thread   ChatThread @relation(fields: [threadId], references: [id])
  sender   User       @relation("SentMessages", fields: [senderId], references: [id])
  receiver User       @relation("RecvMessages", fields: [receiverId], references: [id])
}

// Server-side saved/liked parties — syncs across devices
model SavedParty {
  id        String   @id @default(cuid())
  userId    String
  partyId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@unique([userId, partyId])
}

// Party view tracking — for analytics + "For You" ranking
model PartyView {
  id        String   @id @default(cuid())
  partyId   String
  userId    String?  // null for anonymous views
  createdAt DateTime @default(now())

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
}

// Party reviews — submitted by guests after attending
model Review {
  id        String   @id @default(cuid())
  partyId   String
  userId    String
  rating    Int      // 1..5
  comment   String   @default("")
  createdAt DateTime @default(now())

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partyId, userId]) // one review per user per party
}

// ===== Menu items (drinks + snacks) — per spec slides 3, 4, 7, 8 =====
model MenuItem {
  id        String   @id @default(cuid())
  partyId   String
  name      String
  price     Int      @default(0) // in major currency units (£ or ₹)
  emoji     String   @default("🍹")
  category  String   @default("drink") // drink | snack | soft
  createdAt DateTime @default(now())

  party    Party       @relation(fields: [partyId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([partyId])
}

// ===== Orders (entry ticket + optional add-ons) — spec slide 4 =====
model Order {
  id              String   @id @default(cuid())
  userId          String
  partyId         String
  totalAmount     Int      @default(0) // in major currency units
  currency        String   @default("£") // £ or ₹
  status          String   @default("pending") // pending | paid | refunded
  stripePaymentId String?
  createdAt       DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id])
  party Party      @relation(fields: [partyId], references: [id])
  items OrderItem[]
  ticket Ticket?

  @@index([userId])
  @@index([partyId])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  menuItemId String? // null for the entry ticket itself
  name       String
  emoji      String @default("🎟️")
  unitPrice  Int    @default(0)
  quantity   Int    @default(1)

  order Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem? @relation(fields: [menuItemId], references: [id])
}

// ===== Tickets (QR-validated door entry) — spec slides 5, 7 =====
model Ticket {
  id          String    @id @default(cuid())
  orderId     String    @unique
  userId      String
  partyId     String
  qrHash      String    @unique // unique scannable hash
  scannedAt   DateTime?
  scannedById String?
  createdAt   DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
  party Party @relation(fields: [partyId], references: [id])

  @@index([userId])
  @@index([partyId])
}

// ===== Guest TRUST ratings — host rates guests after a party =====
// Hosts give guests a TRUST score (1..5) + optional note after the party.
// The avg is shown on the guest's profile as an assurity signal for future
// hosts. "TRUST" is distinct from the host's "vibe" rating — it specifically
// signals whether the guest was respectful, showed up, and didn't cause issues.
model TrustRating {
  id        String   @id @default(cuid())
  partyId   String
  // hostId gives the rating; guestId receives it
  hostId    String
  guestId   String
  rating    Int      // 1..5
  note      String   @default("")
  createdAt DateTime @default(now())

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
  host  User  @relation("TrustGiven", fields: [hostId], references: [id])
  guest User  @relation("TrustReceived", fields: [guestId], references: [id])

  @@unique([partyId, guestId]) // one trust rating per guest per party
  @@index([guestId])
}

// ===== Group chat (unlocked after first payment) — spec purchase-flow rewrite =====
// One group chat per party. Created when the first guest pays (or the host
// flips groupChatEnabled). All paid guests + the host are members. Hosts the
// referral-offer cards (Swiggy/Zomato/Blinkit/Zepto/BigBasket/Instamart/Flipkart).
model GroupChat {
  id        String   @id @default(cuid())
  partyId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  party    Party              @relation(fields: [partyId], references: [id], onDelete: Cascade)
  members  GroupChatMember[]
  messages GroupChatMessage[]

  @@index([partyId])
}

model GroupChatMember {
  id          String   @id @default(cuid())
  groupChatId String
  userId      String
  joinedAt    DateTime @default(now())

  groupChat GroupChat @relation(fields: [groupChatId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupChatId, userId])
  @@index([userId])
}

model GroupChatMessage {
  id          String   @id @default(cuid())
  groupChatId String
  senderId    String
  content     String
  // kind = "text" | "system" | "offer" (referral card)
  kind        String   @default("text")
  // For offer messages: which brand (swiggy|zomato|blinkit|zepto|bigbasket|instamart|flipkart)
  offerBrand  String?
  createdAt   DateTime @default(now())

  groupChat GroupChat @relation(fields: [groupChatId], references: [id], onDelete: Cascade)

  @@index([groupChatId])
}
